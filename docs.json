{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PolyNode",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb",
    "background": {
      "dark": "#0a0f1a"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/websocket",
              "guides/errors",
              "guides/rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "/openapi.json",
        "groups": [
          {
            "group": "Markets",
            "pages": [
              "api-reference/markets/top-markets",
              "api-reference/markets/market-detail",
              "api-reference/markets/market-by-slug",
              "api-reference/markets/market-by-condition-id",
              "api-reference/markets/filtered-market-listing",
              "api-reference/markets/search-markets"
            ]
          },
          {
            "group": "Pricing",
            "pages": [
              "api-reference/pricing/market-statistics",
              "api-reference/pricing/ohlcv-candles"
            ]
          },
          {
            "group": "Settlements",
            "pages": [
              "api-reference/settlements/recent-settlements",
              "api-reference/settlements/settlements-by-wallet",
              "api-reference/settlements/settlements-by-token"
            ]
          },
          {
            "group": "Wallets",
            "pages": [
              "api-reference/wallets/wallet-activity"
            ]
          },
          {
            "group": "RPC",
            "pages": [
              "api-reference/rpc/json-rpc-proxy"
            ]
          },
          {
            "group": "System",
            "pages": [
              "api-reference/system/system-status",
              "api-reference/system/generate-api-key",
              "api-reference/system/health-check",
              "api-reference/system/readiness-check"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/joinQuantish/polygon-node",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "API Status",
        "href": "https://polynode.dev/v1/status"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://polynode.dev"
    }
  },
  "api": {
    "baseUrl": "https://polynode.dev",
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "feedback": {
    "thumbsRating": true
  }
}
